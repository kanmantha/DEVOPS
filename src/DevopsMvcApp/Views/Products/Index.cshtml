@model IEnumerable<Product>

@{
    ViewData["Title"] = "Products";
    var search = ViewBag.Search as string;
    var sortBy = ViewBag.SortBy as string ?? "name";
    var sortDir = ViewBag.SortDir as string ?? "asc";
    var curPage = (int)ViewBag.Page;
    var totalPages = (int)ViewBag.TotalPages;
    var total = (int)ViewBag.Total;
}

<div class="page-header">
    <div>
        <h1 class="page-title">Products</h1>
        <p class="page-subtitle">@total product(s) found</p>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-primary">+ New Product</a>
    </div>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input name="search" class="form-control" placeholder="Search products..." value="@search" />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-primary w-100">Search</button>
    </div>
    <div class="col-md-6 text-end">
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

@if (Model.Count() == 0)
{
    <div class="empty-state">
        <div class="empty-icon">📦</div>
        <h3>No Products</h3>
        <p>@(string.IsNullOrEmpty(search) ? "Create your first product to get started." : "No products match your search.")</p>
        <a asp-action="Create" class="btn btn-primary">Create Product</a>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-devops">
                <thead>
                    <tr>
                        <th><a asp-action="Index" asp-route-search="@search" asp-route-sortBy="name" asp-route-sortDir="@(sortBy == "name" && sortDir == "asc" ? "desc" : "asc")" asp-route-p="@curPage" class="text-decoration-none text-reset">Name @(sortBy == "name" ? (sortDir == "asc" ? "▲" : "▼") : "")</a></th>
                        <th><a asp-action="Index" asp-route-search="@search" asp-route-sortBy="price" asp-route-sortDir="@(sortBy == "price" && sortDir == "asc" ? "desc" : "asc")" asp-route-p="@curPage" class="text-decoration-none text-reset">Price @(sortBy == "price" ? (sortDir == "asc" ? "▲" : "▼") : "")</a></th>
                        <th><a asp-action="Index" asp-route-search="@search" asp-route-sortBy="stock" asp-route-sortDir="@(sortBy == "stock" && sortDir == "asc" ? "desc" : "asc")" asp-route-p="@curPage" class="text-decoration-none text-reset">Stock @(sortBy == "stock" ? (sortDir == "asc" ? "▲" : "▼") : "")</a></th>
                        <th><a asp-action="Index" asp-route-search="@search" asp-route-sortBy="created" asp-route-sortDir="@(sortBy == "created" && sortDir == "asc" ? "desc" : "asc")" asp-route-p="@curPage" class="text-decoration-none text-reset">Created @(sortBy == "created" ? (sortDir == "asc" ? "▲" : "▼") : "")</a></th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold"><a asp-action="Details" asp-route-id="@item.Id">@item.Name</a></td>
                            <td>@item.Price.ToString("C2")</td>
                            <td>@item.Stock</td>
                            <td>@item.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Details</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(curPage <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-search="@search" asp-route-sortBy="@sortBy" asp-route-sortDir="@sortDir" asp-route-p="@(curPage - 1)">Previous</a>
            </li>
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == curPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-search="@search" asp-route-sortBy="@sortBy" asp-route-sortDir="@sortDir" asp-route-p="@i">@i</a>
                </li>
            }
            <li class="page-item @(curPage >= totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-search="@search" asp-route-sortBy="@sortBy" asp-route-sortDir="@sortDir" asp-route-p="@(curPage + 1)">Next</a>
            </li>
        </ul>
    </nav>
}