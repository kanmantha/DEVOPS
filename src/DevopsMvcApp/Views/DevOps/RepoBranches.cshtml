@model List<BranchInfo>

@{
    ViewData["Title"] = "Branches";
    var repoId = ViewBag.RepoId as string;
    var repoName = ViewBag.RepoName as string ?? "Repository";
}

<div class="page-header">
    <div>
        <h1 class="page-title">@repoName</h1>
        <p class="page-subtitle">Branches</p>
    </div>
    <div>
        <a asp-action="RepoFiles" asp-route-repoId="@repoId" class="btn btn-outline-primary btn-sm">Browse Files</a>
        <a asp-action="Repositories" class="btn btn-outline-secondary btn-sm">All Repos</a>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <h5 class="fw-bold mb-3">Create Branch</h5>
        <form asp-action="CreateBranch" method="post" class="row g-2 align-items-end">
            <input type="hidden" name="repoId" value="@repoId" />
            <div class="col-md-4">
                <label class="form-label">Branch Name</label>
                <input name="branchName" class="form-control" placeholder="feature/my-feature" required />
            </div>
            <div class="col-md-4">
                <label class="form-label">Source Branch (optional)</label>
                <select name="sourceBranch" class="form-select">
                    <option value="">Default branch</option>
                    @foreach (var b in Model)
                    {
                        <option value="@b.Name">@b.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Create</button>
            </div>
        </form>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">🌿</div>
        <h3>No Branches</h3>
        <p>No branches found in this repository.</p>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-devops">
                <thead>
                    <tr>
                        <th>Branch</th>
                        <th>Commit</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var branch in Model)
                    {
                        <tr>
                            <td class="fw-semibold">🌿 @branch.Name</td>
                            <td><code>@branch.ObjectId[..8]</code></td>
                            <td class="text-end">
                                <a asp-action="RepoFiles" asp-route-repoId="@repoId" asp-route-branch="@branch.Name"
                                   class="btn btn-sm btn-outline-info">Browse</a>
                                <form asp-action="DeleteBranch" method="post" class="d-inline"
                                      onsubmit="return confirm('Delete branch @branch.Name permanently?')">
                                    <input type="hidden" name="repoId" value="@repoId" />
                                    <input type="hidden" name="branchName" value="@branch.Name" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}