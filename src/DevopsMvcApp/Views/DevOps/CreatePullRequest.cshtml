@model CreatePullRequestRequest

@{
    ViewData["Title"] = "Create Pull Request";
    var repos = ViewBag.Repositories as List<DevOpsRepository> ?? new();
}

<div class="page-header">
    <h1 class="page-title">Create Pull Request</h1>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body p-4">
                <form asp-action="CreatePullRequest" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="RepositoryId" class="form-label">Repository</label>
                        <select asp-for="RepositoryId" class="form-select">
                            @foreach (var repo in repos)
                            {
                                <option value="@repo.Id">@repo.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Title</label>
                        <input asp-for="Title" class="form-control" placeholder="PR title" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Describe the changes..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label asp-for="SourceBranch" class="form-label">Source Branch</label>
                        <input asp-for="SourceBranch" class="form-control" placeholder="feature/my-feature" />
                        <span asp-validation-for="SourceBranch" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="TargetBranch" class="form-label">Target Branch</label>
                        <input asp-for="TargetBranch" class="form-control" value="main" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Create PR</button>
                        <a asp-action="PullRequests" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
