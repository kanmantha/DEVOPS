@model CreateRepositoryRequest

@{
    ViewData["Title"] = "Create Repository";
}

<div class="page-header">
    <h1 class="page-title">Create Repository</h1>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body p-4">
                <form asp-action="CreateRepository" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Repository Name</label>
                        <input asp-for="Name" class="form-control" placeholder="my-repo" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Create</button>
                        <a asp-action="Repositories" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
