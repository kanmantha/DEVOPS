@model List<BuildTimelineRecord>

@{
    ViewData["Title"] = "Build Timeline";
    var buildId = ViewBag.BuildId as int?;
    var buildNumber = ViewBag.BuildNumber as string ?? $"#{buildId}";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Build @buildNumber</h1>
        <p class="page-subtitle">Timeline</p>
    </div>
    <div>
        <a asp-action="Builds" class="btn btn-outline-secondary">&larr; Back</a>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">📋</div>
        <h3>No Timeline Records</h3>
        <p>This build doesn't have timeline data yet.</p>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-devops">
                <thead>
                    <tr>
                        <th>Step</th>
                        <th>State</th>
                        <th>Result</th>
                        <th>Duration</th>
                        <th class="text-end">Log</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var record in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@record.Name</td>
                            <td><span class="badge bg-secondary rounded-pill">@record.State</span></td>
                            <td>
                                <span class="badge rounded-pill @(record.Result == "succeeded" ? "bg-success" : record.Result == "failed" ? "bg-danger" : record.Result == "skipped" ? "bg-warning" : "bg-secondary")">
                                    @(record.Result ?? "Running...")
                                </span>
                            </td>
                            <td>
                                @if (record.StartTime.HasValue && record.FinishTime.HasValue)
                                {
                                    var dur = record.FinishTime.Value - record.StartTime.Value;
                                    @dur.ToString(@"mm\:ss")
                                }
                            </td>
                            <td class="text-end">
                                @if (record.LogId.HasValue)
                                {
                                    <a asp-action="BuildLog" asp-route-buildId="@buildId" asp-route-logId="@record.LogId" asp-route-stepName="@record.Name"
                                       class="btn btn-sm btn-outline-dark">Logs</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
