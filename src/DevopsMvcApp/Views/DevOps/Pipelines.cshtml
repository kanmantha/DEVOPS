@model List<DevOpsPipeline>

@{
    ViewData["Title"] = "Pipelines";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Pipelines</h1>
        <p class="page-subtitle">@Model.Count pipeline(s) configured</p>
    </div>
    <div>
        <a asp-action="CreatePipeline" class="btn btn-primary">+ New Pipeline</a>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">⚡</div>
        <h3>No Pipelines</h3>
        <p>Create your first CI/CD pipeline to automate builds and deployments.</p>
        <a asp-action="CreatePipeline" class="btn btn-primary">Create Pipeline</a>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-devops">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Folder</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pipeline in Model)
                    {
                        <tr>
                            <td class="fw-semibold"><a href="@pipeline.WebUrl" target="_blank">@pipeline.Name</a></td>
                            <td>@pipeline.Folder</td>
                            <td class="text-end">
                                <a asp-action="PipelineRuns" asp-route-id="@pipeline.Id" asp-route-name="@pipeline.Name" class="btn btn-sm btn-outline-info">Runs</a>
                                <a asp-action="RunPipeline" asp-route-id="@pipeline.Id" class="btn btn-sm btn-outline-success">Run</a>
                                <form asp-action="DeletePipeline" method="post" class="d-inline"
                                      onsubmit="return confirm('Delete pipeline @pipeline.Name permanently?')">
                                    <input type="hidden" name="id" value="@pipeline.Id" />
                                    <input type="hidden" name="name" value="@pipeline.Name" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
