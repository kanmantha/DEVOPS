@model UploadFileRequest

@{
    ViewData["Title"] = "Upload File";
    var repos = ViewBag.Repositories as List<DevOpsRepository> ?? new();
}

<div class="page-header">
    <h1 class="page-title">Upload File</h1>
    <p class="page-subtitle">Commit a new file directly to a repository branch</p>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body p-4">
                <form asp-action="UploadFile" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="RepositoryId" class="form-label">Repository</label>
                        <select asp-for="RepositoryId" class="form-select">
                            @foreach (var repo in repos)
                            {
                                <option value="@repo.Id">@repo.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Branch" class="form-label">Branch</label>
                        <input asp-for="Branch" class="form-control" value="main" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="FilePath" class="form-label">File Path</label>
                        <input asp-for="FilePath" class="form-control" placeholder="src/MyApp/hello.txt" />
                        <div class="form-text">Path where the file will be created in the repo.</div>
                        <span asp-validation-for="FilePath" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Content" class="form-label">Content</label>
                        <textarea asp-for="Content" class="form-control" rows="10" placeholder="Write file content here..."></textarea>
                        <span asp-validation-for="Content" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Comment" class="form-label">Commit Message</label>
                        <input asp-for="Comment" class="form-control" value="File uploaded via DevOps Portal" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">Commit File</button>
                        <a asp-action="Repositories" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
