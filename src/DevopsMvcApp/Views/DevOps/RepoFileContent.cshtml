@model FileContent

@{
    ViewData["Title"] = Model.Name;
}

<div class="page-header">
    <div>
        <h1 class="page-title" style="font-size:1.25rem;">@Model.Name</h1>
        <p class="page-subtitle">
            <code>@Model.Path</code> &middot; Branch: <strong>@Model.Branch</strong>
        </p>
    </div>
    <div>
        <a asp-action="RepoFiles" asp-route-repoId="@Model.RepositoryId"
           asp-route-path="@(Model.Path.Contains('/') ? Model.Path[..Model.Path.LastIndexOf('/')] : "")"
           asp-route-branch="@Model.Branch"
            class="btn btn-outline-secondary btn-sm">&larr; Back</a>
        <a asp-action="EditFile" asp-route-repoId="@Model.RepositoryId"
           asp-route-path="@Model.Path" asp-route-branch="@Model.Branch"
           class="btn btn-sm btn-outline-warning">Edit</a>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>File Content</span>
        <span class="badge bg-secondary rounded-pill">@Model.Encoding</span>
    </div>
    <div class="card-body p-0">
        <pre class="mb-0" style="border-radius:0 0 var(--radius) var(--radius);"><code>@Model.Content</code></pre>
    </div>
</div>
