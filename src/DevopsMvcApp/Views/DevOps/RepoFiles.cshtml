@model List<RepoFile>

@{
    ViewData["Title"] = "Browse Files";
    var repoId = ViewBag.RepoId as string;
    var currentPath = ViewBag.CurrentPath as string ?? "";
    var branch = ViewBag.Branch as string ?? "main";
    var repoName = ViewBag.RepoName as string ?? "Repository";
}

<div class="page-header">
    <div>
        <h1 class="page-title">@repoName</h1>
        <p class="page-subtitle">
            Branch: <strong>@branch</strong> &middot;
            Path: <code>@(string.IsNullOrEmpty(currentPath) ? "/" : currentPath)</code>
        </p>
    </div>
    <div>
        <a asp-action="RepoCommits" asp-route-repoId="@repoId" class="btn btn-outline-info btn-sm">Commits</a>
        <a asp-action="RepoBranches" asp-route-repoId="@repoId" class="btn btn-outline-secondary btn-sm">Branches</a>
        <a asp-action="UploadFile" class="btn btn-outline-success btn-sm">+ Upload</a>
        <a asp-action="Repositories" class="btn btn-outline-primary btn-sm">All Repos</a>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">📂</div>
        <h3>Empty Folder</h3>
        <p>This folder has no files.</p>
        <a asp-action="UploadFile" class="btn btn-success">Upload File</a>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-devops">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Size</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!string.IsNullOrEmpty(currentPath))
                    {
                        var parent = currentPath.Contains('/') ? currentPath[..currentPath.LastIndexOf('/')] : "";
                        <tr>
                            <td>
                                <a asp-action="RepoFiles" asp-route-repoId="@repoId" asp-route-path="@parent" asp-route-branch="@branch" class="fw-semibold">
                                    ..
                                </a>
                            </td>
                            <td></td>
                            <td></td>
                        </tr>
                    }
                    @foreach (var file in Model)
                    {
                        <tr>
                            <td>
                                @if (file.IsFolder)
                                {
                                    <a asp-action="RepoFiles" asp-route-repoId="@repoId" asp-route-path="@file.Path" asp-route-branch="@branch" class="fw-semibold">
                                        📁 @file.Name
                                    </a>
                                }
                                else
                                {
                                    <a asp-action="RepoFileContent" asp-route-repoId="@repoId" asp-route-path="@file.Path" asp-route-branch="@branch">
                                        📄 @file.Name
                                    </a>
                                }
                            </td>
                            <td>
                                @if (!file.IsFolder)
                                {
                                    @(file.Size > 1024 ? $"{file.Size / 1024} KB" : $"{file.Size} B")
                                }
                            </td>
                            <td class="text-end">
                                @if (!file.IsFolder)
                                {
                                    <a asp-action="RepoFileContent" asp-route-repoId="@repoId" asp-route-path="@file.Path" asp-route-branch="@branch"
                                       class="btn btn-sm btn-outline-primary">View</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
