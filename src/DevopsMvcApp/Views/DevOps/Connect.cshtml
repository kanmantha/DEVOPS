@model DevOpsConnection

@{
    ViewData["Title"] = "Connect to Azure DevOps";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Connect to Azure DevOps</h1>
        <p class="page-subtitle">Enter your organization credentials to manage repos, pipelines, and more</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card">
            <div class="card-body p-4">
                <form asp-action="Connect" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Organization" class="form-label">Organization</label>
                        <div class="input-group">
                            <span class="input-group-text">https://dev.azure.com/</span>
                            <input asp-for="Organization" class="form-control" placeholder="vinnukanmanthareddy" />
                        </div>
                        <div class="form-text">Enter only the organization name (not the full URL).</div>
                        <span asp-validation-for="Organization" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Project" class="form-label">Project</label>
                        <input asp-for="Project" class="form-control" placeholder="Hospital_Management" />
                        <span asp-validation-for="Project" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Pat" class="form-label">Personal Access Token</label>
                        <input asp-for="Pat" class="form-control font-monospace" placeholder="Paste your PAT here" />
                        <span asp-validation-for="Pat" class="text-danger"></span>
                        <div class="form-text">
                            Generate a PAT with <strong>Code (Read/Write)</strong>, <strong>Pipeline (Read/Write)</strong>,
                            and <strong>Build (Read/Write)</strong> scopes at
                            <a href="https://dev.azure.com/_usersSettings/tokens" target="_blank">Azure DevOps Tokens</a>.
                            Make sure the token has no extra spaces or newlines.
                        </div>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">Connect</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
